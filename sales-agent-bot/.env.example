# ─────────────────────────────────────────────────────────────
# OpenAI (the agent's brain)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional. Defaults to gpt-4.1. Any function-calling model works (e.g. gpt-4o).
AGENT_MODEL=gpt-4.1

# ─────────────────────────────────────────────────────────────
# Slack (only needed to run the bot; not needed for `npm run ask`)
# Create app at https://api.slack.com/apps → enable Socket Mode.
# ─────────────────────────────────────────────────────────────
# Bot User OAuth Token (OAuth & Permissions). Scopes:
#   app_mentions:read, chat:write, channels:history, groups:history,
#   im:history, im:read, im:write, reactions:write
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token (Basic Information → App-Level Tokens) with scope: connections:write
SLACK_APP_TOKEN=xapp-...

# ─────────────────────────────────────────────────────────────
# Notion (https://www.notion.so/my-integrations → internal integration)
# Then "Connect" the integration to the pages/teamspaces it should read.
# ─────────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...

# ─────────────────────────────────────────────────────────────
# Google Drive (read-only). Two options:
#
# A) Service account (recommended). Create one in Google Cloud, enable the
#    Drive API, download the JSON key. Then either:
#      - share the relevant Drive folders/docs with the service account email, OR
#      - set GOOGLE_IMPERSONATE_SUBJECT + enable domain-wide delegation.
#    Provide the key as a single-line JSON string OR a file path:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
# GOOGLE_IMPERSONATE_SUBJECT=you@yourcompany.com   # optional, domain-wide delegation
#
# B) Skip Google Drive entirely — the bot still works with Notion alone.
# ─────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_IMPERSONATE_SUBJECT=
