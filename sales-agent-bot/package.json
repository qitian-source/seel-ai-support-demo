{
  "name": "seel-sales-agent-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Slack bot that helps Seel sales answer questions about customers and the AI Workforce, grounded in Notion + Google Drive.",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "ask": "tsx src/cli.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@notionhq/client": "^5.1.0",
    "@slack/bolt": "^4.4.0",
    "dotenv": "^17.0.0",
    "googleapis": "^144.0.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
